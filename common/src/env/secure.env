
# needs to be deifined only if the server run in https protocol

HTTP_PROTOCOL=false # 'Indicates id the server is run in https protocol'

# certs
CA_CERT_PATH=# 'The path to the CA cert to identify the clietn certs'
SERVER_KEY_PATH=# 'The path to the server key of the server certificates'
SERVER_CERT_PATH=# 'The path to the server cert of the server certificates'


# ###################### PROXY SUCURE ENV #########################
DIST_HTTP_PROTOCOL=true # "true - false // Indicates when the server is acting as a proxy if the destination server is running with the https protocol"

GETAPP_SSL_URL=# The url of the distination server with the protocol of https 'google.com' not 'https://google.com'
GETAPP_SSL_PORT=# "The port of the distination server"

# client certs
CLIENT_KEY_PATH=# 'The path to the client key of the clietn certificates'
CLIENT_KEY_PATH=# 'The path to the client cert of the clietn certificates'


# ###################### HASHICORP VAULT #########################
#
# Vault is DISABLED by default (plain-text legacy mode) unless auth credentials are set.
# VAULT_ADDR defaults to http://vault:8200 – matches the Docker Compose service name
# and a Kubernetes service named "vault" in the same namespace, so it rarely needs overriding.
#
# Minimum required to enable Vault (local dev with docker-compose):
#   VAULT_TOKEN=getapp-vault-token
#
# When enabled, SSH keys and HTTPS passwords are stored in Vault KV v2 instead of
# plain text. DB columns hold a reference: vault:{mountPath}/{gitSourceId}#{field}
# On startup, any existing plain-text credentials are migrated automatically.

# Override only when Vault is not reachable at http://vault:8200
# VAULT_ADDR=http://vault:8200

# Authentication – set ONE of the following:

# Option 1: Static token (local dev / simple setups)
# e.g. getapp-vault-token
VAULT_TOKEN=

# Option 2: AppRole (recommended for production)
# VAULT_ROLE_ID=
# VAULT_SECRET_ID=

# Override only when using a custom KV mount path (auto-created if missing)
# VAULT_MOUNT_PATH=getapp-secrets
